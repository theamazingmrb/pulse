# Priority Compass Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL — set to your production domain
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Spotify — create an app at developer.spotify.com
# Add your redirect URI to your app's Redirect URIs in the Spotify dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your-spotify-client-id
NEXT_PUBLIC_SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# Google Calendar — create credentials at console.cloud.google.com
# Enable Google Calendar API and add the redirect URI
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_CLIENT_SECRET=your-google-client-secret

# VAPID Keys for Web Push Notifications
# Generate with: node scripts/generate-vapid-keys.js
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@prioritycompass.app

# Supabase Edge Function Cron Secret (for notification scheduling)
CRON_SECRET=your-random-cron-secret-key